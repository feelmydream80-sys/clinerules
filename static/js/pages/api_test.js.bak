/**
 * API 테스트 페이지 메인 로직
 * 
 * 이 파일은 API 테스트 페이지의 모든 상호작용을 관리합니다.
 * 페이지 로드 시 다음 작업을 수행합니다:
 * 1. 기본 날짜 범위 설정 (오늘로부터 한 달 전 ~ 오늘)
 * 2. 탭 기반 UI 초기화
 * 3. API 호출 기능 설정
 * 4. 응답 표시 영역 관리
 */
document.addEventListener('DOMContentLoaded', () => {
    /**
     * 날짜를 YYYY-MM-DD 형식의 문자열로 변환
     * @param {Date} date - 변환할 Date 객체
     * @returns {string} YYYY-MM-DD 형식의 날짜 문자열
     */
    const formatDate = (date) => {
        const y = date.getFullYear();
        const m = String(date.getMonth() + 1).padStart(2, '0');
        const d = String(date.getDate()).padStart(2, '0');
        return `${y}-${m}-${d}`;
    };

    // 기본 날짜 범위 설정 (오늘로부터 한 달 전 ~ 오늘)
    const today = new Date();
    const oneMonthAgo = new Date(today);
    oneMonthAgo.setMonth(today.getMonth() - 1);
    
    const todayDate = formatDate(today);
    const oneMonthAgoDate = formatDate(oneMonthAgo);

    /**
     * API 그룹 및 엔드포인트 정의
     * 각 탭에 표시될 API 목록을 정의합니다.
     * - 키: 탭 제목 (이모티콘 포함)
     * - 값: 해당 탭의 API 목록 (배열)
     *   - title: API 이름
     *   - endpoint: API 엔드포인트 URL
     *   - method: HTTP 메소드 (GET/POST 등)
     *   - defaultData: 기본 요청 데이터
     */
    const apiGroups = {
        "📊 Dashboard": [
            { title: "대시보드 요약", endpoint: "/api/dashboard/summary", method: "GET", defaultData: { start_date: oneMonthAgoDate, end_date: todayDate, all_data: "false" } },
            { title: "최소/최대 날짜", endpoint: "/api/dashboard/min-max-dates", method: "GET", defaultData: {} }
        ],
        "📈 Analytics": [
            { title: "수집 성공률 추이", endpoint: "/api/analytics/success_rate_trend", method: "GET", defaultData: { start_date: oneMonthAgoDate, end_date: todayDate } },
            { title: "장애 코드별 비율", endpoint: "/api/analytics/trouble_by_code", method: "GET", defaultData: { start_date: oneMonthAgoDate, end_date: todayDate } }
        ],
        "🔍 Data Analysis": [
            { title: "요약/통계", endpoint: "/api/analysis/summary", method: "GET", defaultData: { start_date: oneMonthAgoDate, end_date: todayDate } },
            { title: "추이/경향", endpoint: "/api/analysis/trend", method: "GET", defaultData: { start_date: oneMonthAgoDate, end_date: todayDate } },
            { title: "원본 데이터", endpoint: "/api/analysis/raw_data", method: "GET", defaultData: { start_date: oneMonthAgoDate, end_date: todayDate } },
            { title: "Job ID 목록", endpoint: "/api/analysis/job_ids", method: "GET", defaultData: {} },
            { title: "장애코드 목록", endpoint: "/api/analysis/error_codes", method: "GET", defaultData: {} },
            { title: "장애코드-이름 매핑", endpoint: "/api/analysis/error_code_map", method: "GET", defaultData: {} }
        ],
        "📋 General": [
            { title: "상세 이력", endpoint: "/api/detail", method: "GET", defaultData: {} },
            { title: "마스터 Job 목록", endpoint: "/api/mst_list", method: "GET", defaultData: {} },
            { title: "Job 상세 정보", endpoint: "/api/job_mst_info", method: "GET", defaultData: { job_ids: "CD101,CD102" } },
            { title: "이벤트 로그", endpoint: "/api/con_hist_event_log", method: "GET", defaultData: { page: 1, page_size: 10, start_date: oneMonthAgoDate, end_date: todayDate } }
        ],
        "🌐 External": [
            { title: "Gemini API 프록시", endpoint: "/api/gemini", method: "POST", defaultData: { contents: [{ parts: [{ text: "Hello, world!" }] }] } }
        ]
    };

    // DOM 요소 참조
    const tabContainer = document.getElementById('tab-container');        // 탭 버튼 컨테이너
    const contentContainer = document.getElementById('tab-content-container'); // 탭 콘텐츠 컨테이너
    const SERVER_URL = window.location.origin;  // 현재 서버 URL (로컬/프로덕션 자동 감지)

    /**
     * 날짜 입력 필드에 기본값 설정
     * 모든 날짜 입력 필드에 오늘 날짜와 한 달 전 날짜를 기본값으로 설정합니다.
     */
    function setDefaultDates() {
        document.querySelectorAll('input[type="date"]').forEach(input => {
            if (input.id.includes('end_date') || input.id.includes('end-date')) {
                input.value = todayDate;
            } else if (input.id.includes('start_date') || input.id.includes('start-date')) {
                input.value = oneMonthAgoDate;
            }
        });
    }

    // 탭 버튼 및 콘텐츠 생성
    function initializeTabs() {
        // 기존 내용 초기화
        tabContainer.innerHTML = '';
        contentContainer.innerHTML = '';

        // 탭 버튼 및 콘텐츠 영역 생성
        Object.keys(apiGroups).forEach((groupName, index) => {
            // 탭 버튼 생성
            const tabButton = document.createElement('button');
            tabButton.className = 'tab-button';
            tabButton.textContent = groupName;
            tabButton.dataset.tab = `tab-${index}`;
            tabContainer.appendChild(tabButton);

            // 콘텐츠 영역 생성
            const contentPane = document.createElement('div');
            contentPane.id = `tab-${index}`;
            contentPane.className = 'tab-content';
            contentContainer.appendChild(contentPane);

            // API 섹션 추가
            apiGroups[groupName].forEach((api, apiIndex) => {
                const apiSection = createApiSection(api, `${index}-${apiIndex}`);
                contentPane.appendChild(apiSection);
            });

            // 탭 클릭 이벤트 리스너
            tabButton.addEventListener('click', () => {
                // 모든 탭 콘텐츠 숨기기
                document.querySelectorAll('.tab-content').forEach(pane => {
                    pane.classList.remove('active');
                });
                // 모든 탭 버튼 비활성화
                document.querySelectorAll('.tab-button').forEach(btn => {
                    btn.classList.remove('active');
                });
                // 현재 탭 활성화
                contentPane.classList.add('active');
                tabButton.classList.add('active');
            });
        });
    }

    /**
     * API 테스트 섹션 생성
     * @param {Object} api - API 정보 객체
     * @param {string} id - 고유 식별자
     * @returns {HTMLElement} 생성된 섹션 요소
     */
    function createApiSection(api, id) {
        const section = document.createElement('div');
        section.className = 'api-section';
        
        // HTTP 메소드에 따른 배지 클래스 설정
        const methodBadgeClass = `badge-${api.method.toLowerCase()}`;
        
        // API 섹션 HTML 생성
        section.innerHTML = `
            <div class="api-section-header">
                <h3>${api.title}</h3>
                <span class="badge ${methodBadgeClass}">${api.method}</span>
            </div>
            <div class="api-section-body">
                <div class="api-input-section">
                    <div class="form-group">
                        <label>API Endpoint</label>
                        <div class="endpoint-display">${api.endpoint}</div>
                    </div>
                    <div class="form-group">
                        <label>Request Data</label>
                        <textarea id="data-${id}" class="request-data" rows="8">${JSON.stringify(api.defaultData, null, 2)}</textarea>
                    </div>
                    <button onclick="testApi(this, '${api.endpoint}', '${api.method}', '${id}')" class="btn-primary">
                        <span class="spinner"></span>
                        <span>API 호출</span>
                    </button>
                </div>
                <div class="api-response-section">
                    <label>Response</label>
                    <pre id="response-${id}" class="response-display">API 호출 후 결과가 여기에 표시됩니다.</pre>
                </div>
            </div>
        `;
        
        return section;
    }

    /**
     * API 테스트 실행 (전역 함수로 노출)
     * @param {HTMLElement} button - 클릭된 버튼 요소
     * @param {string} endpoint - API 엔드포인트
     * @param {string} method - HTTP 메소드
     * @param {string} id - 고유 식별자
     */
    window.testApi = async function(button, endpoint, method, id) {
        const dataElement = document.getElementById(`data-${id}`);
        const responseArea = document.getElementById(`response-${id}`);
        const spinner = button.querySelector('.spinner');
        
        try {
            // 로딩 상태 표시
            button.disabled = true;
            spinner.style.display = 'inline-block';
            responseArea.textContent = '요청을 처리 중입니다...';
            
            // 요청 데이터 파싱
            let requestData = {};
            try {
                requestData = JSON.parse(dataElement.value);
            } catch (e) {
                throw new Error('유효한 JSON 형식이 아닙니다.');
            }
            
            // URL에 파라미터 치환 (RESTful 파라미터용)
            let url = endpoint;
            const queryParams = new URLSearchParams();
            
            // URL 내 {param} 패턴 치환
            Object.keys(requestData).forEach(key => {
                const placeholder = `{${key}}`;
                if (url.includes(placeholder)) {
                    url = url.replace(placeholder, encodeURIComponent(requestData[key]));
                    delete requestData[key];
                } else if (method === 'GET') {
                    // GET 요청의 경우 쿼리 파라미터로 추가
                    if (requestData[key] !== null && requestData[key] !== '') {
                        queryParams.append(key, requestData[key]);
                    }
                }
            });
            
            // GET 요청의 경우 쿼리 파라미터 추가
            if (queryParams.toString() && method === 'GET') {
                url += (url.includes('?') ? '&' : '?') + queryParams.toString();
            }
            
            // 요청 옵션 설정
            const options = {
                method: method,
                headers: {
                    'Content-Type': 'application/json',
                },
                credentials: 'same-origin'
            };
            
            // POST/PUT/PATCH 요청의 경우 본문 추가
            if (method !== 'GET' && Object.keys(requestData).length > 0) {
                options.body = JSON.stringify(requestData);
            }
            
            // API 호출
            const response = await fetch(url, options);
            const responseData = await response.json();
            
            // 응답 표시
            responseArea.textContent = JSON.stringify(responseData, null, 2);
            responseArea.className = response.ok ? 'response-display success' : 'response-display error';
            
        } catch (error) {
            console.error('API 호출 중 오류 발생:', error);
            responseArea.textContent = `오류 발생: ${error.message}`;
            responseArea.className = 'response-display error';
        } finally {
            // 버튼 상태 초기화
            button.disabled = false;
            spinner.style.display = 'none';
        }
    };

    // 페이지 초기화
    setDefaultDates();
    initializeTabs();
    
    // 기본적으로 첫 번째 탭 활성화
    const firstTab = document.querySelector('.tab-button');
    if (firstTab) firstTab.click();
});
